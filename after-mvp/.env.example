# ============================================================================
# After MVP - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
PORT=3000

# ----------------------------------------------------------------------------
# IBM Pro Mode Configuration (Optional)
# ----------------------------------------------------------------------------
# Set to "true" to enable IBM Cloud services integration
# Leave empty or set to "false" to run in local-only mode
IBM_PRO_ENABLED=false


IBM_WATSONX_API_KEY=your_watsonx_api_key_here
IBM_WATSONX_PROJECT_ID=your_watsonx_project_id_here
IBM_WATSONX_MODEL=ibm/granite-3-8b-instruct
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# IBM Bob Shell (optional)
# Install and authenticate IBM Bob Shell first, then either keep "bob" on PATH
# or set this to the full executable path, for example:
# BOB_SHELL_PATH=C:\Path\To\bob.exe
BOB_SHELL_PATH=



IBM_TTS_API_KEY=your_tts_api_key_here
IBM_TTS_URL=https://api.us-south.text-to-speech.watson.cloud.ibm.com/instances/your_tts_instance_id_here
IBM_TTS_VOICE=en-US_MichaelV3Voice


# Example Cloudant credential fields from IBM Cloud:
#   "apikey": "your_cloudant_api_key_here",
#   "host": "your_cloudant_host_here.cloudantnosqldb.appdomain.cloud",
#   "iam_apikey_description": "your_cloudant_key_description_here",
#   "iam_apikey_id": "your_cloudant_api_key_id_here",
#   "iam_apikey_name": "your_cloudant_api_key_name_here",
#   "iam_role_crn": "crn:v1:bluemix:public:iam::::serviceRole:Manager",
#   "iam_serviceid_crn": "your_cloudant_service_id_crn_here",
#   "url": "https://your_cloudant_host_here.cloudantnosqldb.appdomain.cloud",
#   "username": "your_cloudant_username_here"
# }
IBM_CLOUDANT_ENABLED=false
IBM_CLOUDANT_URL=https://your_cloudant_host_here.cloudantnosqldb.appdomain.cloud
IBM_CLOUDANT_API_KEY=your_cloudant_api_key_here
IBM_CLOUDANT_DATABASE=after-brain

# ----------------------------------------------------------------------------
# IBM Natural Language Understanding Configuration (Optional - Future Use)
# ----------------------------------------------------------------------------
# For advanced code analysis and entity extraction
# Get your credentials from: https://cloud.ibm.com/catalog/services/natural-language-understanding
#
# Steps to get credentials:
# 1. Go to https://cloud.ibm.com/catalog/services/natural-language-understanding
# 2. Choose a region and plan (Lite is free)
# 3. Click "Create"
# 4. Go to "Manage" → copy API key and URL
IBM_NLU_ENABLED=false
IBM_NLU_API_KEY=your_nlu_api_key_here
IBM_NLU_URL=https://api.us-south.natural-language-understanding.watson.cloud.ibm.com/instances/your_nlu_instance_id_here

# ============================================================================
# Security Notes
# ============================================================================
# 1. NEVER commit this file with real credentials
# 2. Use different API keys for development and production
# 3. Rotate API keys regularly (every 90 days recommended)
# 4. Use IBM Cloud IAM for fine-grained access control
# 5. Monitor API usage in IBM Cloud dashboard
# 6. Set up billing alerts to avoid unexpected charges
# ============================================================================
